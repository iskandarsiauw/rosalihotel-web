Options -Indexes

# Force PHP 8.5 (EasyApache 4 / Rumahweb)
<FilesMatch "\.php$">
    SetHandler application/x-httpd-ea-php85
</FilesMatch>

# Block direct access to includes/
<FilesMatch "\.(sql)$">
  Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^includes/ - [F,L]
</IfModule>
